# ── Codespaces / local dev ──────────────────────────────────
POSTGRES_URL=postgresql://postgres:pass@localhost:5432/warranty_claims
NEXT_PUBLIC_USE_BLOB_UPLOAD=false

# Auth (required — use 32+ char random string for AUTH_SECRET)
AUTH_SECRET=llkUg5jOl0sd1g2jf5lh890jO2KFT9==
# Seeded into users table on first boot (also works as shared-password fallback)
ADJUSTER_PASSWORD=Abcde123
SUPERVISOR_PASSWORD=Abcde123
# Default seeded emails: adjuster@fwcut.local, supervisor@fwcut.local

# AI (optional locally — uses heuristic fallback without Grok)
GROK_API_KEY=
AI_MODEL=grok-3-mini
AI_VISION_MODEL=grok-3

# ── Freedom Warranty FWIS (fwis.freedomwarranty.com) ────────
# Paste the API key from Freedom when you receive it:
FWIS_API_KEY=
# FWIS_BASE_URL=https://fwis.freedomwarranty.com
# FWIS_ENABLED=true
# Auth style: bearer | api_key_header | raw_authorization
# FWIS_AUTH_STYLE=bearer
# FWIS_API_KEY_HEADER=X-API-Key
# Optional path overrides once Freedom shares OpenAPI routes:
# FWIS_PATH_HEALTH=/api/health
# FWIS_PATH_POLICY=/api/v1/policies/{policyNumber}
# FWIS_PATH_CLAIM=/api/v1/claims/{claimId}
# FWIS_PATH_DECISION=/api/v1/claims/{claimId}/decisions
# Set true only after push endpoint is confirmed:
# FWIS_PUSH_DECISIONS=false

# ── Vercel production (auto-set by Storage integrations) ────
# POSTGRES_URL=
# BLOB_READ_WRITE_TOKEN=
# NEXT_PUBLIC_USE_BLOB_UPLOAD=true
# AUTH_SECRET=          ← generate: openssl rand -base64 32
# ADJUSTER_PASSWORD=    ← set a strong production password
# SUPERVISOR_PASSWORD=  ← optional, for supervisor role